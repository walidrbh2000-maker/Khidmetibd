# ── Ollama ────────────────────────────────────────────────────────────────────
#
# MODÈLE : gemma3:4b
#
# POURQUOI gemma3:4b pour Codespace 32 GB / 16 GB RAM :
#   - 4B paramètres denses, architecture Gemma 3 (Google DeepMind)
#   - Taille disque : ~3.3 GB (Q4_K_M, tag a2af6cc3eb7f — confirmé Ollama registry)
#   - RAM nécessaire : ~3.5 GB chargé
#   - Contexte : 128K tokens (on limite à 4096 pour économiser le KV cache)
#   - Multimodal : texte + image (JPEG, PNG, WebP — analyse de photos de sinistres)
#   - 140+ langues : arabe, français, anglais, darija algérienne ✅
#   - Prérequis Ollama : >= 0.6 (disponible depuis mars 2025)
#
# CAS D'USAGE KHIDMETI (photos + texte) :
#   - Chambre en désordre → détection besoin ménage
#   - Fuite de canalisation → plombier urgence
#   - Prise électrique brûlée → électricien urgence
#   - Texte darija : "عندي ماء ساقط من السقف" → extraction JSON intention
#
# POURQUOI PAS gemma4:e2b (7.2 GB) :
#   Sur Codespace 32 GB : images Docker ~20-24 GB + 7.2 GB = dépassement.
#   Le pull échoue avec "no space left on device" (~6.5 GB téléchargés / 7.2 GB).
#   gemma3:4b (3.3 GB) laisse ~5-9 GB libres → pull réussit toujours.
#
# MODÈLES PAR TIER (disque requis / RAM chargée) :
#   Codespace 32 GB → gemma3:4b    (3.3 GB / ~3.5 GB)   ← CE SETUP ✅
#   Codespace 32 GB → gemma3:1b    (0.8 GB / ~1.0 GB)   ← fallback, texte seul
#   VPS 100 GB      → gemma4:e2b   (7.2 GB / ~6-7 GB)   ← audio+vision+reasoning
#   GPU 8 GB VRAM   → gemma3:4b    (3.3 GB / ~3.5 GB)   ← rapide sur GPU
#
# NOTE AUDIO :
#   gemma3:4b ne supporte PAS l'audio. Ce n'est pas un problème :
#   Khidmeti utilise faster-whisper (conteneur séparé) pour la transcription.
#   L'audio est converti en texte par Whisper AVANT d'être envoyé à Ollama.
#
# NUM_CTX = 4096 :
#   Sur 16 GB RAM : gemma3:4b chargé (~3.5 GB) + services (~2.5 GB) = ~6 GB
#   Le KV cache pour 4096 tokens ≈ 200 MB → total ~6.2 GB sur 16 GB ✅
#   128K context natif = KV cache ~8 GB → dépasse le budget RAM disponible ❌
#
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=gemma3:4b
OLLAMA_TIMEOUT_MS=120000
OLLAMA_NUM_CTX=2048

# ── faster-whisper (transcription audio) ─────────────────────────────────────
# CPU → Systran/faster-whisper-small   (multilingue, ~466 MB, int8)
# GPU → Systran/faster-whisper-large-v3 (meilleure qualité, float16)
WHISPER_BASE_URL=http://whisper:8000
WHISPER_MODEL=Systran/faster-whisper-small

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9001
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=khidmeti
MINIO_SECRET_KEY=khidmeti123
MINIO_PUBLIC_URL=http://${MACHINE_HOST}:9001

# ── MapTiler ──────────────────────────────────────────────────────────────────
MAPTILER_API_KEY=btE7rXDcH3x6nBHcYTUY

