# ══════════════════════════════════════════════════════════════════════════════
# ── IA / LLM ─────────────────────────────────────────────────────────────────
# ══════════════════════════════════════════════════════════════════════════════
#
# STRATÉGIE RECOMMANDÉE : AI_PROVIDER=openrouter
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ openrouter : Gemma 4 31B GRATUIT (texte + image) + Gemini (audio)      │
# │   → 95% des appels = coût 0                                             │
# │   → Audio Darija/Arabe = Gemini 2.5 flash-lite (très bon marché)       │
# │                                                                         │
# │ gemini     : Tout via Google AI Studio (payant)                         │
# │ ollama     : Gemma4 local (zéro coût, nécessite Ollama installé)        │
# └─────────────────────────────────────────────────────────────────────────┘
#
AI_PROVIDER=openrouter

# ── OpenRouter ────────────────────────────────────────────────────────────────
# Clé gratuite : https://openrouter.ai/keys
# Le modèle google/gemma-4-31b-it:free est 100% gratuit (quota généreux)
OPENROUTER_API_KEY=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

# Modèle OpenRouter pour texte + image (laisser tel quel = gratuit)
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Timeout en ms (35s pour absorber le cold-start du modèle)
OPENROUTER_TIMEOUT_MS=35000

# ── Google AI Studio (requis uniquement pour l'audio) ────────────────────────
# Clé : https://aistudio.google.com/apikey
# Utilisé UNIQUEMENT pour processAudio() (transcription Darija/Arabe/Français)
# Coût : ~$0.001 / minute audio avec gemini-2.5-flash-lite
GEMINI_API_KEY=AIzaSyCQvpDkWn6xQ1ixLuV9_D3ZZsfRtn1Lv28

# Modèle audio Gemini (flash-lite = moins cher, très bonne qualité Darija)
GEMINI_AUDIO_MODEL=gemini-2.5-flash-lite

# ── Ollama (optionnel — pour basculer sur local) ──────────────────────────────
# AI_PROVIDER=ollama pour utiliser ces paramètres à la place d'OpenRouter
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=gemma4:e4b
OLLAMA_TIMEOUT_MS=30000

# ── Qdrant ─────────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333

# ── MinIO ──────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9001
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=khidmeti
MINIO_SECRET_KEY=khidmeti123
MINIO_PUBLIC_URL=http://${MACHINE_HOST}:9001

# ── MapTiler ───────────────────────────────────────────────────────────────────
MAPTILER_API_KEY=btE7rXDcH3x6nBHcYTUY

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://${MACHINE_HOST}:80
