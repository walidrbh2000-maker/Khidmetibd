# ── Ollama ────────────────────────────────────────────────────────────────────
#
# MODÈLE : gemma4:e2b
#
# POURQUOI gemma4:e2b pour 16 GB RAM CPU :
#   - 2.3B paramètres effectifs, 5.1B total avec embeddings (PLE)
#   - Taille disque : ~7.2 GB (q4_K_M multimodal avec projecteurs vision+audio)
#   - RAM nécessaire : ~6-7 GB chargé
#   - Contexte : 128K tokens (on limite à 8192 pour rester dans le budget RAM)
#   - Multimodal : texte + image + audio
#   - Meilleure qualité que gemma3:2b sur les benchmarks reasoning/coding
#
# ⚠️  ATTENTION TAILLE DISQUE :
#   gemma4:e2b = 7.2 GB (confirmé Ollama registry)
#   Ce n'est PAS un modèle 2B classique : il embarque des projecteurs
#   multimodaux (vision encoder + audio encoder) qui grossissent le GGUF.
#   Prérequis : ~8 GB d'espace disque libre avant `make ollama-pull`.
#   Si disk full → `docker system prune -f` puis réessayer.
#
# PRÉREQUIS OLLAMA :
#   gemma4 nécessite Ollama >= v0.20.0 (sorti le 2 avril 2025)
#   La commande `make start` force le pull de la dernière image Ollama.
#
# MODÈLES PAR TIER MÉMOIRE RAM :
#   CPU  8 GB  → gemma3:2b    (~1.9 GB disque, ~2.0 GB RAM)   ← seule option viable
#   CPU 16 GB  → gemma4:e2b   (~7.2 GB disque, ~6-7 GB RAM)   ← RECOMMANDÉ (ce setup)
#   CPU 16 GB  → gemma4:e4b   (~9.6 GB disque, ~8-9 GB RAM)   ← RAM limite
#   GPU  8 GB  → gemma4:e2b   (~7.2 GB disque, ~7 GB VRAM)    ← parfait
#   GPU 24 GB  → gemma4:26b   (~18 GB disque,  ~18 GB VRAM)   ← puissance max
#
# NUM_CTX = 8192 :
#   Sur 16 GB RAM : gemma4:e2b chargé (~7 GB) + services (~2.5 GB) = ~9.5 GB
#   Le KV cache pour 8192 tokens ≈ 400 MB → total ~9.9 GB sur 16 GB ✅
#   128K context = KV cache ~12 GB → dépasse les ressources disponibles ❌
#
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=gemma4:e2b
OLLAMA_TIMEOUT_MS=120000
OLLAMA_NUM_CTX=8192

# ── faster-whisper (transcription audio) ─────────────────────────────────────
# CPU → Systran/faster-whisper-small   (multilingue, ~466 MB, int8)
# GPU → Systran/faster-whisper-large-v3 (meilleure qualité, float16)
WHISPER_BASE_URL=http://whisper:8000
WHISPER_MODEL=Systran/faster-whisper-small

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9001
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=khidmeti
MINIO_SECRET_KEY=khidmeti123
MINIO_PUBLIC_URL=http://${MACHINE_HOST}:9001

