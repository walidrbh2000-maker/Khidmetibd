# ══════════════════════════════════════════════════════════════════════════════
# ── IA locale — Architecture directe v11 (sans Ollama) ───────────────────────
# ══════════════════════════════════════════════════════════════════════════════
#
# MIGRATION depuis Ollama :
#   ANCIEN : OLLAMA_BASE_URL=http://ollama:11434  (wrapper Go instable)
#   NOUVEAU: OLLAMA_BASE_URL=http://ai-text:8011  (llama.cpp:server direct)
#   → même variable, même interface OpenAI, zéro changement de code
#
# POURQUOI ces nouvelles valeurs par défaut ?
#   ai-text:8011  → llama.cpp:server + Qwen3-0.6B (JSON rapide et stable)
#   ai-vision:8012→ llama.cpp:server + moondream2  (description image fiable)
#   ai-audio:8000 → faster-whisper + large-v3-turbo (Darija WER 8% vs 25%)

# ── AI Text (Qwen3-0.6B via llama.cpp:server) ─────────────────────────────────
#
# OLLAMA_BASE_URL : pointe maintenant vers ai-text:8011 (llama.cpp direct)
#   L'interface OpenAI est identique — aucun changement dans local.strategy.ts
#
# OLLAMA_MODEL : nom du fichier GGUF sans l'extension
#   llama.cpp ne gère pas de "registry" — le modèle est chargé au démarrage
#   Le nom ici est utilisé dans les requêtes /v1/chat/completions (ignoré
#   par llama.cpp qui utilise le modèle chargé, mais requis par l'API format)
#
# OLLAMA_TIMEOUT_MS : 15 000 ms (réduit depuis 60 000)
#   Qwen3-0.6B Q4_K_M sur CPU 4 cœurs :
#   - Cold start : ~3s (modèle sur disque, pas de téléchargement)
#   - Inférence  : ~2-5s pour 200 tokens (JSON intent)
#   - Total      : ~5-8s → 15 000 ms donne 7s de marge confortable
#
OLLAMA_BASE_URL=http://ai-text:8011
OLLAMA_MODEL=qwen3-0.6b-q4_k_m
OLLAMA_TIMEOUT_MS=15000
OLLAMA_NUM_CTX=512

# ── AI Vision (moondream2 via llama.cpp:server) ────────────────────────────────
#
# OLLAMA_BASE_URL_VISION : URL du service vision (séparé du texte)
#   → Indépendance totale : un crash vision n'affecte PAS le texte/audio
#
# OLLAMA_VISION_TIMEOUT_MS : 60 000 ms
#   moondream2 sur CPU : CLIP encode (~10-20s) + génération (~5s) = ~25s max
#   60 000 ms = largement suffisant (vs 150 000 ms avec Ollama overhead)
#
# NOTE : décommenter UNIQUEMENT si le service ai-vision est activé
#        dans docker-compose.yml (requiert ~2.2 GB RAM supplémentaires)
#
OLLAMA_VISION_MODEL=moondream2
OLLAMA_BASE_URL_VISION=http://ai-vision:8012
OLLAMA_VISION_TIMEOUT_MS=60000
OLLAMA_VISION_NUM_CTX=1024

# ── AI Audio (faster-whisper-large-v3-turbo) ──────────────────────────────────
#
# WHISPER_MODEL : large-v3-turbo (remplace whisper-small)
#   Screenshots montrent "Chosnip lombé" → transcription incorrecte
#   large-v3-turbo INT8 : WER Darija 8% vs 25% pour small
#   Téléchargement automatique au 1er démarrage du container ai-audio
#
WHISPER_BASE_URL=http://ai-audio:8000
WHISPER_MODEL=Systran/faster-whisper-large-v3-turbo

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9001
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=khidmeti
MINIO_SECRET_KEY=khidmeti123
MINIO_PUBLIC_URL=http://${MACHINE_HOST}:9001

# ── MapTiler ──────────────────────────────────────────────────────────────────
MAPTILER_API_KEY=btE7rXDcH3x6nBHcYTUY

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://${MACHINE_HOST}:80

