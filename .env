# ══════════════════════════════════════════════════════════════════════════════
# ── IA — Gemma4 E2B (CPU) / E4B (GPU) via llama.cpp:server ───────────────────
# ══════════════════════════════════════════════════════════════════════════════

# ── AI Gemma4 (texte + images — llama.cpp:server) ─────────────────────────────
#
# GEMMA4_CTX_SIZE :
#   8 GB RAM  → 4096  (safe : ~4.0 GB model + ~0.35 GB KV + overhead)
#   16 GB RAM → 8192  (comfortable)
#   32 GB RAM → 16384 (large context for agentic use)
#
# GEMMA4_MODEL_FILE / GEMMA4_MMPROJ_FILE :
#   Noms des fichiers dans docker/models/gemma4/ après make download-gemma4
#   CPU (E2B) : gemma-4-e2b-it-Q4_K_M.gguf + mmproj-gemma-4-e2b-it-f32.gguf
#   GPU (E4B) : gemma-4-e4b-it-Q4_K_M.gguf + mmproj-gemma-4-e4b-it-f32.gguf
#
GEMMA4_BASE_URL=http://ai-gemma4:8011
GEMMA4_TIMEOUT_MS=30000
GEMMA4_CTX_SIZE=4096
GEMMA4_MODEL_FILE=gemma-4-e2b-it-Q4_K_M.gguf
GEMMA4_MMPROJ_FILE=mmproj-gemma-4-e2b-it-f32.gguf

# ── AI Audio (faster-whisper-large-v3-turbo) ──────────────────────────────────
#
# Whisper reste le provider audio :
# Le support audio natif Gemma4 via llama.cpp est en développement (avril 2026)
# → Whisper transcrit → texte envoyé à Gemma4 pour extraction d'intention
#
WHISPER_BASE_URL=http://ai-audio:8000
WHISPER_MODEL=Systran/faster-whisper-large-v3-turbo

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9001
