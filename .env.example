# ── App ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# ── MongoDB ───────────────────────────────────────────────────────────────
MONGO_ROOT_USER=khidmeti_admin
MONGO_ROOT_PASSWORD=change_me_strong_password
MONGODB_URI=mongodb://khidmeti_admin:change_me_strong_password@mongo:27017/khidmeti?authSource=admin

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@redis:6379

# ── Firebase (service account — no JSON file, env vars only) ─────────────
# Get these from Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the private key with literal \n — do NOT use actual newlines
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXXX\n-----END PRIVATE KEY-----\n"

# ── AI Provider Strategy ──────────────────────────────────────────────────
# Options: gemini | ollama | vllm
# DEFAULT: gemini — works on any machine, no GPU needed, free tier sufficient for dev/demo
AI_PROVIDER=gemini

# Gemini (AI_PROVIDER=gemini) — requires internet, no extra container
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama (AI_PROVIDER=ollama) — local inference, needs 16GB+ RAM
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=gemma4:e2b
OLLAMA_TIMEOUT_MS=15000

# Whisper — used with Ollama provider for audio transcription
WHISPER_BASE_URL=http://whisper:9000

# vLLM (AI_PROVIDER=vllm) — GPU required, NVIDIA 16GB+ VRAM
VLLM_BASE_URL=http://vllm:8000
HF_TOKEN=your_huggingface_token_here

# ── Qdrant ────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ── MinIO (replaces Cloudinary — S3-compatible self-hosted) ──────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9001
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=khidmeti_minio_user
MINIO_SECRET_KEY=change_me_minio_password
MINIO_BUCKET_PROFILES=profile-images
MINIO_BUCKET_MEDIA=service-media
MINIO_BUCKET_AUDIO=audio-recordings
# Public URL used for building file URLs returned to Flutter clients
MINIO_PUBLIC_URL=http://localhost:9001

# ── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins in production
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
